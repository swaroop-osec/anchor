---
interface Props {
  title?: string
}

const { title } = Astro.props
---

<div class="step grid grid-cols-[1.75rem_1fr] gap-x-3 sm:grid-cols-[2rem_1fr] sm:gap-x-4">
  <div class="flex flex-col items-center">
    <div
      class="step-num bg-background text-muted-foreground flex size-7 shrink-0 items-center justify-center rounded-full border-2 text-xs leading-none font-medium tabular-nums sm:size-8 sm:text-sm"
    >
    </div>
    <div class="step-connector bg-border w-0.5 grow"></div>
  </div>
  <div class="step-content min-w-0 pb-6 sm:pb-8">
    {
      title && (
        <span class="mb-3 flex min-h-7 items-center text-base sm:min-h-8 sm:text-lg">{title}</span>
      )
    }
    <div class="prose max-w-none sm:pt-0.5" data-step-content>
      <slot />
    </div>
  </div>
</div>

<style>
  @layer components {
    [data-step-content] > :global(*:first-child) {
      margin-top: 0 !important;
    }
    [data-step-content] > :global(*:last-child),
    [data-step-content] > :global(*:last-child) > :global(*:last-child),
    [data-step-content] > :global(*:last-child) > :global(*:last-child) > :global(*:last-child),
    [data-step-content]
      > :global(*:last-child)
      > :global(*:last-child)
      > :global(*:last-child)
      > :global(*:last-child) {
      margin-bottom: 0 !important;
    }
  }

  .step {
    counter-increment: step;
  }

  .step-num::before {
    content: counter(step);
  }

  .step:last-child .step-connector {
    display: none;
  }

  .step:last-child .step-content {
    padding-bottom: 0;
  }
</style>
