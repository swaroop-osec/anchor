---
import { cn } from '@/lib/utils'
import { cva, type VariantProps } from 'class-variance-authority'

const badgeVariants = cva(
  'inline-flex items-center rounded px-1.5 py-0.5 text-[0.65rem] font-medium leading-none',
  {
    variants: {
      variant: {
        default: 'bg-muted text-muted-foreground',
        note: 'bg-blue-500/10 text-blue-600 dark:text-blue-400',
        tip: 'bg-lime-500/10 text-lime-600 dark:text-lime-400',
        caution: 'bg-amber-500/10 text-amber-600 dark:text-amber-400',
        danger: 'bg-red-500/10 text-red-600 dark:text-red-400',
      },
    },
    defaultVariants: {
      variant: 'default',
    },
  },
)

type Variant = NonNullable<VariantProps<typeof badgeVariants>['variant']>

interface Props {
  variant?: Variant
  class?: string
}

const { variant = 'default', class: className } = Astro.props
---

<span class={cn(badgeVariants({ variant }), className)}>
  <slot />
</span>
