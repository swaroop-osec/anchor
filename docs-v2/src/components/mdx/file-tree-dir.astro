---
import Icon from '@/components/icon.astro'

interface Props {
  name: string
  open?: boolean
  highlight?: boolean
  comment?: string
}

const { name, open = true, highlight = false, comment } = Astro.props
const hasChildren = Astro.slots.has('default')
---

{
  hasChildren ? (
    <li>
      <details open={open || undefined}>
        <summary
          class:list={[
            'hover:bg-muted/60 focus-visible:ring-ring inline-flex cursor-pointer list-none items-center gap-1.5 rounded px-1.5 py-0.5 whitespace-nowrap select-none focus-visible:ring-2 focus-visible:outline-none',
            highlight && 'bg-primary/10 text-primary font-medium',
          ]}
        >
          <Icon
            name="chevron-right"
            class="text-muted-foreground size-3 shrink-0 transition-transform [[open]>summary>&]:rotate-90"
          />
          <Icon name="folder" class="text-muted-foreground size-4 shrink-0" />
          <span class="font-mono">{name}/</span>
          {comment && <span class="text-muted-foreground/75 ml-2">{comment}</span>}
        </summary>
        <ul class="mt-0.5 ml-[11px] list-none space-y-0.5 border-l-2 pl-3">
          <slot />
        </ul>
      </details>
    </li>
  ) : (
    <li>
      <span
        class:list={[
          'inline-flex items-center gap-1.5 rounded px-1.5 py-0.5 whitespace-nowrap',
          highlight && 'bg-primary/10 text-primary font-medium',
        ]}
      >
        <span class="size-3 shrink-0" aria-hidden="true" />
        <Icon name="folder" class="text-muted-foreground size-4 shrink-0" />
        <span class="font-mono">{name}/</span>
        {comment && <span class="text-muted-foreground/75 ml-2">{comment}</span>}
      </span>
    </li>
  )
}
