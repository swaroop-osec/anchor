---
import wordmarkDark from '@/assets/wordmark-dark.svg'
import wordmarkLight from '@/assets/wordmark-light.svg'
import SearchTrigger from '@/components/docs/search-trigger.astro'
import Icon from '@/components/icon.astro'
import Link from '@/components/link.astro'
import ThemeToggle from '@/components/theme-toggle.astro'
import { Button } from '@/components/ui/button'
import { DOCS, SITE } from '@/consts'
import { BASE_URL } from '@/lib/docs'
import { Image } from 'astro:assets'
---

<div class="mx-auto flex w-full items-center justify-between gap-3 px-4 py-3">
  <div class="flex items-center gap-3">
    <Button
      id="mobile-sidebar-trigger"
      variant="ghost"
      size="icon"
      title="Open navigation"
      aria-label="Open navigation"
      aria-controls="mobile-sidebar"
      aria-expanded="false"
      className="-my-2 -ms-2 size-8"
    >
      <Icon name="menu-2" class="size-4" />
    </Button>
    <Link href={BASE_URL} class="flex shrink-0 items-center no-underline" aria-label={SITE.title}>
      <Image src={wordmarkLight} alt={SITE.title} class="block h-5 w-auto dark:hidden" />
      <Image src={wordmarkDark} alt={SITE.title} class="hidden h-5 w-auto dark:block" />
    </Link>
  </div>

  <div class="flex items-center gap-1">
    {DOCS.search.enabled && <SearchTrigger />}
    <ThemeToggle transition:persist />
  </div>
</div>
