---
import Icon from '@/components/icon.astro'
import Link from '@/components/link.astro'
import { DOCS } from '@/consts'

const announcement = DOCS.announcement
const announcementId = announcement?.id ?? ''
---

<script is:inline data-astro-rerun define:vars={{ announcementId }}>
  if (announcementId) {
    try {
      const dismissed = localStorage.getItem(`announcement-dismissed:${announcementId}`) === '1'
      document.documentElement.toggleAttribute('data-docs-announcement-dismissed', dismissed)
      if (dismissed) {
        document.documentElement.style.setProperty('--docs-announcement-offset', '0px')
      }
    } catch {}
  }
</script>

<style is:inline>
  html[data-docs-announcement-dismissed] [data-announcement-id] {
    display: none !important;
  }
</style>

{
  announcement && (
    <div
      id={`announcement-${announcement.id}`}
      data-announcement-id={announcement.id}
      class="bg-foreground text-background grid min-h-8 grid-cols-[minmax(0,1fr)_1.5rem] items-center gap-2 px-3 py-1.5 text-center text-sm"
    >
      {announcement.href ? (
        <Link
          href={announcement.href}
          class="text-background hover:text-background decoration-background/50 hover:decoration-background inline-flex min-w-0 items-center justify-center gap-1.5 leading-tight font-medium"
          external={announcement.href.startsWith('http')}
        >
          <span class="min-w-0 text-balance">{announcement.message}</span>
          <Icon name="arrow-right" class="hidden size-3.5 shrink-0 sm:block" />
        </Link>
      ) : (
        <span>{announcement.message}</span>
      )}
      <button
        type="button"
        class="text-background/70 hover:text-background inline-flex size-6 shrink-0 items-center justify-center"
        aria-label="Dismiss announcement"
        data-announcement-dismiss
      >
        <Icon name="x" class="size-4" />
      </button>
    </div>
  )
}

<script>
  import { mountAnnouncementBar } from '@/lib/client/announcement'

  mountAnnouncementBar()
</script>
