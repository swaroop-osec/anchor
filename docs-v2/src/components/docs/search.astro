---
import Icon from '@/components/icon.astro'
---

<dialog
  id="search-dialog"
  class="bg-background text-foreground fixed top-24 left-1/2 m-0 w-[min(40rem,90vw)] -translate-x-1/2 overflow-hidden rounded-lg border p-0 shadow-lg backdrop:bg-black/40 backdrop:backdrop-blur-sm open:flex open:flex-col"
  aria-label="Search documentation"
>
  <form method="dialog" class="border-border/70 flex items-center gap-2 border-b px-3 py-2">
    <Icon name="search" class="text-muted-foreground size-4" />
    <input
      type="search"
      id="search-input"
      placeholder="Search documentation..."
      autocomplete="off"
      aria-controls="search-results"
      class="flex-1 border-0 bg-transparent py-1 text-sm outline-none"
    />
    <kbd
      class="text-muted-foreground bg-muted rounded border px-1.5 py-0.5 font-mono text-[0.625rem]"
      >Esc</kbd
    >
  </form>
  <div
    id="search-results"
    class="flex max-h-[min(24rem,60vh)] flex-col overflow-y-auto p-2 text-sm"
  >
    <p id="search-empty" class="text-muted-foreground px-3 py-8 text-center text-sm">
      Start typing to search the docs.
    </p>
  </div>
</dialog>

<script>
  import { mountDocsSearch } from '@/lib/client/search'

  mountDocsSearch()
</script>
