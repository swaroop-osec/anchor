---
import Icon from '@/components/icon.astro'
import { renderDescription } from '@/lib/render-description'
import { cn } from '@/lib/utils'

const calloutConfig = {
  note: { color: 'var(--tone-blue)', icon: 'info-circle' },
  tip: { color: 'var(--tone-green)', icon: 'bulb' },
  warning: { color: 'var(--tone-yellow)', icon: 'alert-triangle' },
  danger: { color: 'var(--tone-red)', icon: 'shield-exclamation' },
  important: { color: 'var(--tone-mauve)', icon: 'message-circle-exclamation' },
  definition: { color: 'var(--tone-lavender)', icon: 'book' },
  theorem: { color: 'var(--tone-teal)', icon: 'circle-check' },
  lemma: { color: 'var(--tone-sapphire)', icon: 'puzzle' },
  proof: { color: 'var(--tone-green)', icon: 'square-check' },
  corollary: { color: 'var(--tone-sky)', icon: 'git-branch' },
  proposition: { color: 'var(--tone-blue)', icon: 'file-text' },
  axiom: { color: 'var(--tone-lavender)', icon: 'book' },
  conjecture: { color: 'var(--tone-pink)', icon: 'help' },
  notation: { color: 'var(--tone-rosewater)', icon: 'ballpen' },
  remark: { color: 'var(--tone-flamingo)', icon: 'message-circle' },
  intuition: { color: 'var(--tone-peach)', icon: 'bulb' },
  recall: { color: 'var(--tone-sapphire)', icon: 'rotate' },
  explanation: { color: 'var(--tone-blue)', icon: 'help' },
  example: { color: 'var(--tone-teal)', icon: 'code' },
  exercise: { color: 'var(--tone-yellow)', icon: 'barbell' },
  problem: { color: 'var(--tone-maroon)', icon: 'alert-circle' },
  answer: { color: 'var(--tone-teal)', icon: 'check' },
  solution: { color: 'var(--tone-green)', icon: 'circle-check' },
  summary: { color: 'var(--tone-sky)', icon: 'list' },
} as const

const capitalize = (str: string) => str.charAt(0).toUpperCase() + str.slice(1)

interface Props {
  title?: string
  class?: string
  variant?: keyof typeof calloutConfig
  defaultOpen?: boolean
}

const { title, variant = 'note', defaultOpen = true, ...rest } = Astro.props as Props
const { color, icon } = calloutConfig[variant]
const renderedTitle = title ? await renderDescription(title) : null
---

<details
  class={cn(
    'relative my-6 border-l-4 border-l-(--callout-color) bg-transparent pl-4 py-3 text-sm',
    '[&[open]>summary_svg:last-child]:rotate-180 [&[open]>summary]:mb-3',
    rest.class,
  )}
  style={`--callout-color: ${color}`}
  data-callout
  {...rest}
  open={defaultOpen}
>
  <summary class="flex cursor-pointer items-center font-medium [&::-webkit-details-marker]:hidden">
    <Icon name={icon} class="mr-2 size-4 shrink-0 text-(--callout-color)" />
    <span class="mr-2 font-medium text-(--callout-color)">
      {capitalize(variant)}
      {
        renderedTitle && (
          <span class="font-normal opacity-70" set:html={` (${renderedTitle.html})`} />
        )
      }
    </span>
    <Icon
      name="chevron-down"
      class="ml-auto h-4 w-4 shrink-0 text-(--callout-color) transition-transform duration-200"
    />
  </summary>
  <div data-callout-body>
    <slot />
  </div>
</details>

<style>
  @layer components {
    summary code {
      font-family: var(--font-mono);
      font-size: 0.9em;
      padding: 0.05em 0.3em;
      border-radius: 0.25rem;
      background: color-mix(in srgb, var(--callout-color) 12%, transparent);
      color: var(--callout-color);
    }
    [data-callout-body] > :global(*:first-child) {
      margin-top: 0 !important;
    }
    [data-callout-body] > :global(*:last-child),
    [data-callout-body] > :global(*:last-child) > :global(*:last-child),
    [data-callout-body] > :global(*:last-child) > :global(*:last-child) > :global(*:last-child),
    [data-callout-body]
      > :global(*:last-child)
      > :global(*:last-child)
      > :global(*:last-child)
      > :global(*:last-child) {
      margin-bottom: 0 !important;
    }
  }
</style>
